  stub({ id: "h-2", topicId: "hashing", title: "Longest Consecutive Sequence", difficulty: "Medium", tags: ["hashset", "array"], problem: "Return length of longest consecutive elements sequence. O(n) time.", constraints: ["0 <= nums.length <= 10⁵"], approach: "Put all nums in a Set. For each n, if n-1 is absent, n is a sequence start. Walk up.", dryRun: ["[100,4,200,1,3,2] → 4 (1,2,3,4)"], solution: "function longestConsecutive(nums) {\n  const s = new Set(nums);\n  let best = 0;\n  for (const n of s) {\n    if (!s.has(n-1)) {\n      let len=1, x=n+1;\n      while (s.has(x)) { x++; len++; }\n      best = Math.max(best, len);\n    }\n  }\n  return best;\n}", timeComplexity: "O(n)", spaceComplexity: "O(n)" }),
