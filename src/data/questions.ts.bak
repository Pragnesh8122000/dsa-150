  stub({ id: "g-2", topicId: "graphs", title: "Course Schedule", difficulty: "Medium", tags: ["graph", "topological-sort", "bfs"], problem: "Can you finish all courses given prerequisites?", constraints: ["1 <= numCourses <= 2000"], approach: "Detect cycle in directed graph via Kahn's algorithm (BFS topo sort).", dryRun: ["numCourses=2, [[1,0]] → true"], solution: "function canFinish(n, prereq) {\n  const g=Array.from({length:n},()=>[]); const indeg=new Array(n).fill(0);\n  for (const [a,b] of prereq) { g[b].push(a); indeg[a]++; }\n  const q=[]; for (let i=0;i<n;i++) if (indeg[i]===0) q.push(i);\n  let done=0; while (q.length) { const u=q.shift(); done++; for (const v of g[u]) if (--indeg[v]===0) q.push(v); }\n  return done===n;\n}", timeComplexity: "O(V+E)", spaceComplexity: "O(V+E)" }),
  stub({ id: "g-3", topicId: "graphs", title: "Number of Connected Components", difficulty: "Medium", tags: ["graph", "union-find"], problem: "Count components in an undirected graph.", constraints: ["0 <= n <= 10⁵"], approach: "Union-Find. Each edge unions two nodes. Answer = distinct roots.", dryRun: ["n=5, [[0,1],[1,2],[3,4]] → 2"], solution: "function countComponents(n, edges) {\n  const p=Array.from({length:n},(_,i)=>i);\n  const find=x=>p[x]===x?x:(p[x]=find(p[x]),p[x]);\n  for (const [a,b] of edges) p[find(a)]=find(b);\n  return new Set(Array.from({length:n},(_,i)=>find(i))).size;\n}", timeComplexity: "O(V+E·α(V))", spaceComplexity: "O(V)" }),

  // Recursion & Backtracking
  stub({ id: "r-1", topicId: "recursion", title: "Subsets", difficulty: "Medium", tags: ["backtracking", "array"], problem: "Return all subsets (the power set).", constraints: ["1 <= nums.length <= 10"], approach: "Backtrack: include or skip each element.", dryRun: ["[1,2,3] → 8 subsets"], solution: "function subsets(nums) {\n  const out=[], cur=[];\n  const bt=(i)=>{ if (i===nums.length) { out.push([...cur]); return; } bt(i+1); cur.push(nums[i]); bt(i+1); cur.pop(); };\n  bt(0); return out;\n}", timeComplexity: "O(n·2ⁿ)", spaceComplexity: "O(n) excl. output" }),
  stub({ id: "r-2", topicId: "recursion", title: "Permutations", difficulty: "Medium", tags: ["backtracking"], problem: "Return all permutations of distinct integers.", constraints: ["1 <= nums.length <= 6"], approach: "Backtrack with a 'used' set, or swap-based in-place.", dryRun: ["[1,2,3] → 6 permutations"], solution: "function permute(nums) {\n  const out=[], cur=[], used=new Set();\n  const bt=()=>{ if (cur.length===nums.length) { out.push([...cur]); return; } for (let i=0;i<nums.length;i++) { if (used.has(i)) continue; used.add(i); cur.push(nums[i]); bt(); cur.pop(); used.delete(i); } };\n  bt(); return out;\n}", timeComplexity: "O(n·n!)", spaceComplexity: "O(n) excl. output" }),
  stub({ id: "r-3", topicId: "recursion", title: "Word Search", difficulty: "Medium", tags: ["backtracking", "matrix"], problem: "Does the word exist in the grid (4-direction paths, no reuse)?", constraints: ["1 <= m,n <= 6"], approach: "DFS from each cell, mark visited, backtrack.", dryRun: ["board=[[A,B,C,E],[S,F,C,S],[A,D,E,E]], word='ABCCED' → true"], solution: "function exist(b,w) {\n  const m=b.length,n=b[0].length;\n  const dfs=(i,j,k)=>{ if (k===w.length) return true; if (i<0||j<0||i>=m||j>=n||b[i][j]!==w[k]) return false; const t=b[i][j]; b[i][j]='#'; const r=dfs(i+1,j,k+1)||dfs(i-1,j,k+1)||dfs(i,j+1,k+1)||dfs(i,j-1,k+1); b[i][j]=t; return r; };\n  for (let i=0;i<m;i++) for (let j=0;j<n;j++) if (dfs(i,j,0)) return true;\n  return false;\n}", timeComplexity: "O(mn·4^L)", spaceComplexity: "O(L)" }),

  // DP
  stub({ id: "dp-1", topicId: "dp", title: "Climbing Stairs", difficulty: "Easy", tags: ["dp", "1d"], problem: "Ways to reach the top taking 1 or 2 steps at a time.", constraints: ["1 <= n <= 45"], approach: "dp[i] = dp[i-1] + dp[i-2] (Fibonacci).", dryRun: ["n=4 → 5 (1111,112,121,211,22)"], solution: "function climbStairs(n) {\n  if (n<3) return n; let a=1,b=2; for (let i=3;i<=n;i++) [a,b]=[b,a+b]; return b;\n}", timeComplexity: "O(n)", spaceComplexity: "O(1)" }),
  stub({ id: "dp-2", topicId: "dp", title: "Coin Change", difficulty: "Medium", tags: ["dp", "unbounded-knapsack"], problem: "Fewest coins to make amount. -1 if impossible.", constraints: ["1 <= coins.length <= 12"], approach: "dp[i] = min coins to make i; for each coin, dp[i] = min(dp[i], dp[i-coin]+1).", dryRun: ["coins=[1,5,10,25], amount=41 → 4 (25+10+5+1)"], solution: "function coinChange(coins, amount) {\n  const dp=new Array(amount+1).fill(Infinity); dp[0]=0;\n  for (let i=1;i<=amount;i++) for (const c of coins) if (c<=i) dp[i]=Math.min(dp[i],dp[i-c]+1);\n  return dp[amount]===Infinity ? -1 : dp[amount];\n}", timeComplexity: "O(amount · n)", spaceComplexity: "O(amount)" }),
  stub({ id: "dp-3", topicId: "dp", title: "Longest Common Subsequence", difficulty: "Medium", tags: ["dp", "2d", "string"], problem: "Length of LCS of two strings.", constraints: ["1 <= m,n <= 1000"], approach: "2D DP: dp[i][j] = dp[i-1][j-1]+1 if match else max(dp[i-1][j], dp[i][j-1]).", dryRun: ["'abcde','ace' → 3"], solution: "function lcs(a,b) {\n  const m=a.length,n=b.length; const dp=Array.from({length:m+1},()=>new Array(n+1).fill(0));\n  for (let i=1;i<=m;i++) for (let j=1;j<=n;j++) dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);\n  return dp[m][n];\n}", timeComplexity: "O(mn)", spaceComplexity: "O(mn)" }),
  stub({ id: "dp-4", topicId: "dp", title: "0/1 Knapsack", difficulty: "Medium", tags: ["dp", "knapsack"], problem: "Max value with weight limit W, each item at most once.", constraints: ["1 <= n <= 100, 1 <= W <= 10⁴"], approach: "1D DP: for each item, iterate w from W down to weight, dp[w] = max(dp[w], dp[w-wt]+val).", dryRun: ["items=[(1,1),(3,4),(4,5),(5,7)], W=7 → 9 (4+5)"], solution: "function knapsack(items, W) {\n  const dp=new Array(W+1).fill(0);\n  for (const [wt,v] of items) for (let w=W;w>=wt;w--) dp[w]=Math.max(dp[w],dp[w-wt]+v);\n  return dp[W];\n}", timeComplexity: "O(n·W)", spaceComplexity: "O(W)" }),
  stub({ id: "dp-5", topicId: "dp", title: "Unique Paths", difficulty: "Medium", tags: ["dp", "2d", "grid"], problem: "Top-left to bottom-right, only right/down moves.", constraints: ["1 <= m,n <= 100"], approach: "dp[i][j] = dp[i-1][j] + dp[i][j-1].", dryRun: ["m=3,n=7 → 28"], solution: "function uniquePaths(m,n) {\n  const dp=new Array(n).fill(1); for (let i=1;i<m;i++) for (let j=1;j<n;j++) dp[j]+=dp[j-1];\n  return dp[n-1];\n}", timeComplexity: "O(mn)", spaceComplexity: "O(n)" }),

  // Greedy
  stub({ id: "gr-1", topicId: "greedy", title: "Jump Game", difficulty: "Medium", tags: ["greedy", "array"], problem: "Can you reach the last index?", constraints: ["1 <= nums.length <= 10⁴"], approach: "Track the farthest reachable index. If i > reach, fail.", dryRun: ["[2,3,1,1,4] → true; [3,2,1,0,4] → false"], solution: "function canJump(nums) {\n  let reach=0; for (let i=0;i<nums.length;i++) { if (i>reach) return false; reach=Math.max(reach,i+nums[i]); }\n  return true;\n}", timeComplexity: "O(n)", spaceComplexity: "O(1)" }),
  stub({ id: "gr-2", topicId: "greedy", title: "Meeting Rooms II", difficulty: "Medium", tags: ["greedy", "heap", "intervals"], problem: "Minimum number of meeting rooms.", constraints: ["1 <= intervals.length <= 10⁴"], approach: "Sort starts, sort ends. Two pointers: when start >= end, reuse room.", dryRun: ["[[0,30],[5,10],[15,20]] → 2"], solution: "function minMeetingRooms(iv) {\n  const s=iv.map(x=>x[0]).sort((a,b)=>a-b), e=iv.map(x=>x[1]).sort((a,b)=>a-b);\n  let rooms=0, end=0; for (const start of s) { if (start>=e[end]) { end++; } else rooms++; }\n  return rooms;\n}", timeComplexity: "O(n log n)", spaceComplexity: "O(n)" }),

  // Binary Search
  stub({ id: "bs-1", topicId: "binary-search", title: "Search in Rotated Sorted Array", difficulty: "Medium", tags: ["binary-search", "array"], problem: "Search target in a rotated sorted array (no duplicates).", constraints: ["1 <= nums.length <= 5000"], approach: "Standard BS, but compute the sorted half each iteration.", dryRun: ["[4,5,6,7,0,1,2], target=0 → 4"], solution: "function search(nums, t) {\n  let lo=0,hi=nums.length-1; while (lo<=hi) { const m=(lo+hi)>>1; if (nums[m]===t) return m; if (nums[lo]<=nums[m]) { if (t>=nums[lo]&&t<nums[m]) hi=m-1; else lo=m+1; } else { if (t>nums[m]&&t<=nums[hi]) lo=m+1; else hi=m-1; } } return -1;\n}", timeComplexity: "O(log n)", spaceComplexity: "O(1)" }),
  stub({ id: "bs-2", topicId: "binary-search", title: "Koko Eating Bananas", difficulty: "Medium", tags: ["binary-search", "search-on-answer"], problem: "Min eating speed to finish all piles within h hours.", constraints: ["1 <= piles.length <= 10⁴"], approach: "Search on answer (speed). Predicate: can finish within h?", dryRun: ["[3,6,7,11], h=8 → 4"], solution: "function minEatingSpeed(piles, h) {\n  let lo=1, hi=Math.max(...piles), ans=hi;\n  const can=k=>piles.reduce((s,p)=>s+Math.ceil(p/k),0)<=h;\n  while (lo<=hi) { const m=(lo+hi)>>1; if (can(m)) { ans=m; hi=m-1; } else lo=m+1; }\n  return ans;\n}", timeComplexity: "O(n log M)", spaceComplexity: "O(1)" }),

  // Sorting
  stub({ id: "so-1", topicId: "sorting", title: "Sort an Array (Merge Sort)", difficulty: "Medium", tags: ["sorting", "merge-sort"], problem: "Sort an array in O(n log n).", constraints: ["1 <= nums.length <= 5*10⁴"], approach: "Merge sort implementation.", dryRun: ["[5,2,3,1] → [1,2,3,5]"], solution: "function sortArray(nums) {\n  if (nums.length<2) return nums; const m=nums.length>>1; const l=sortArray(nums.slice(0,m)), r=sortArray(nums.slice(m)); const out=[]; let i=0,j=0; while (i<l.length&&j<r.length) out.push(l[i]<r[j]?l[i++]:r[j++]); return out.concat(l.slice(i)).concat(r.slice(j));\n}", timeComplexity: "O(n log n)", spaceComplexity: "O(n)" }),

  // Bit Manipulation
  stub({ id: "bi-1", topicId: "bits", title: "Single Number", difficulty: "Easy", tags: ["bits", "xor"], problem: "Every element appears twice except one. Find it.", constraints: ["1 <= nums.length <= 3*10⁴"], approach: "XOR all — duplicates cancel.", dryRun: ["[4,1,2,1,2] → 4"], solution: "function singleNumber(nums) { return nums.reduce((a,b)=>a^b, 0); }", timeComplexity: "O(n)", spaceComplexity: "O(1)" }),
  stub({ id: "bi-2", topicId: "bits", title: "Number of 1 Bits", difficulty: "Easy", tags: ["bits"], problem: "Count set bits (Hamming weight).", constraints: ["0 <= n <= 2³¹ - 1"], approach: "Brian Kernighan: n & (n-1) clears lowest set bit.", dryRun: ["n=11 (1011) → 3"], solution: "function hammingWeight(n) { let c=0; while (n) { n &= n-1; c++; } return c; }", timeComplexity: "O(k) where k = set bits", spaceComplexity: "O(1)" }),
  stub({ id: "bi-3", topicId: "bits", title: "Subsets via Bitmask", difficulty: "Medium", tags: ["bits", "recursion"], problem: "Return all subsets using bit manipulation.", constraints: ["1 <= n <= 10"], approach: "For each mask 0..(1<<n)-1, take element i if bit i is set.", dryRun: ["[1,2,3] → 8 subsets"], solution: "function subsets(nums) { const out=[]; for (let m=0;m<(1<<nums.length);m++) { const s=[]; for (let i=0;i<nums.length;i++) if (m>>i&1) s.push(nums[i]); out.push(s); } return out; }", timeComplexity: "O(n·2ⁿ)", spaceComplexity: "O(n) excl. output" }),

  // Fillers to round out the catalog to 150 across the topics
  ...generateFillers(),
];

function generateFillers(): Question[] {
  // A handful of additional "real" classic problems per topic to approach 150.
  const fillers: Omit<Question, "buildTrace" | "sampleInput">[] = [
    // Arrays
    { id: "arr-6", topicId: "arrays", title: "Contains Duplicate", difficulty: "Easy", tags: ["hashset"], problem: "True if any value appears at least twice.", constraints: ["1 <= n <= 10⁵"], approach: "Set membership check.", dryRun: ["[1,2,3,1] → true"], solution: "function hasDup(a){return new Set(a).size!==a.length;}", timeComplexity: "O(n)", spaceComplexity: "O(n)" },
    { id: "arr-7", topicId: "arrays", title: "Rotate Array", difficulty: "Medium", tags: ["array", "in-place"], problem: "Rotate right by k steps in-place.", constraints: ["0 <= k <= 10⁵"], approach: "Triple reverse.", dryRun: ["[1,2,3,4,5,6,7], k=3 → [5,6,7,1,2,3,4]"], solution: "function rotate(a,k){k%=a.length; reverse(a,0,a.length-1); reverse(a,0,k-1); reverse(a,k,a.length-1);}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "arr-8", topicId: "arrays", title: "Merge Sorted Array", difficulty: "Easy", tags: ["array", "two-pointers"], problem: "Merge nums2 into nums1 in-place, both sorted.", constraints: ["0 <= m+n <= 200"], approach: "Fill from the back.", dryRun: ["nums1=[1,2,3,0,0,0], m=3, nums2=[2,5,6], n=3 → [1,2,2,3,5,6]"], solution: "function merge(a,m,b,n){let i=m-1,j=n-1,k=m+n-1; while (j>=0) a[k--] = i>=0&&a[i]>b[j]?a[i--]:b[j--];}", timeComplexity: "O(m+n)", spaceComplexity: "O(1)" },
    { id: "arr-9", topicId: "arrays", title: "Longest Substring Without Repeating Chars", difficulty: "Medium", tags: ["sliding-window", "hashset"], problem: "Length of longest substring with all unique chars.", constraints: ["0 <= s.length <= 5*10⁴"], approach: "Sliding window + set; shrink when duplicate.", dryRun: ["'abcabcbb' → 3"], solution: "function lengthOfLongestSubstring(s){const set=new Set();let l=0,best=0;for(let r=0;r<s.length;r++){while(set.has(s[r])){set.delete(s[l]);l++;}set.add(s[r]);best=Math.max(best,r-l+1);}return best;}", timeComplexity: "O(n)", spaceComplexity: "O(min(n,α))" },
    { id: "arr-10", topicId: "arrays", title: "Spiral Matrix", difficulty: "Medium", tags: ["matrix"], problem: "Return elements of matrix in spiral order.", constraints: ["1 <= m,n <= 10"], approach: "Maintain four boundaries, shrink on each direction.", dryRun: ["[[1,2,3],[4,5,6],[7,8,9]] → [1,2,3,6,9,8,7,4,5]"], solution: "function spiralOrder(m){const out=[];let t=0,b=m.length-1,l=0,r=m[0].length-1;while(t<=b&&l<=r){for(let i=l;i<=r;i++)out.push(m[t][i]);t++;for(let i=t;i<=b;i++)out.push(m[i][r]);r--;if(t<=b){for(let i=r;i>=l;i--)out.push(m[b][i]);b--;}if(l<=r){for(let i=b;i>=t;i--)out.push(m[i][l]);l++;}}return out;}", timeComplexity: "O(mn)", spaceComplexity: "O(1) excl. output" },

    // Hashing
    { id: "h-4", topicId: "hashing", title: "Two Sum (Hash)", difficulty: "Easy", tags: ["hashmap", "array"], problem: "Indices of two numbers adding to target.", constraints: ["Exactly one solution"], approach: "Hashmap of value→index, O(n).", dryRun: ["[2,7,11,15], 9 → [0,1]"], solution: "function twoSum(nums,t){const m=new Map();for(let i=0;i<nums.length;i++){const c=t-nums[i];if(m.has(c))return[m.get(c),i];m.set(nums[i],i);}}", timeComplexity: "O(n)", spaceComplexity: "O(n)" },
    { id: "h-5", topicId: "hashing", title: "Subarray Sum Equals K", difficulty: "Medium", tags: ["hashmap", "prefix-sum"], problem: "Count subarrays with sum exactly k.", constraints: ["1 <= n <= 2*10⁴"], approach: "Prefix sum + map of seen prefix counts. For each i, look for (prefix[i]-k).", dryRun: ["[1,1,1], k=2 → 2"], solution: "function subarraySum(nums,k){const m=new Map([[0,1]]);let p=0,c=0;for(const n of nums){p+=n;c+=m.get(p-k)??0;m.set(p,(m.get(p)??0)+1);}return c;}", timeComplexity: "O(n)", spaceComplexity: "O(n)" },
    { id: "h-6", topicId: "hashing", title: "Longest Repeating Character Replacement", difficulty: "Medium", tags: ["sliding-window", "hashmap"], problem: "Same string, k replacements, longest substring of one char.", constraints: ["0 <= k <= s.length"], approach: "Sliding window tracking max char count; window valid if (length - max) <= k.", dryRun: ["'ABAB', k=2 → 4"], solution: "function characterReplacement(s,k){const c=new Array(26).fill(0);let l=0,max=0;for(let r=0;r<s.length;r++){max=Math.max(max,++c[s.charCodeAt(r)-65]);if(r-l+1-max>k){c[s.charCodeAt(l)-65]--;l++;}}return s.length-l;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },

    // Two pointers extras
    { id: "tp-3", topicId: "two-pointers", title: "3Sum", difficulty: "Medium", tags: ["two-pointers", "sorting"], problem: "All unique triplets summing to 0.", constraints: ["0 <= n <= 3000"], approach: "Sort, fix i, two-pointer on remaining. Skip duplicates.", dryRun: ["[-1,0,1,2,-1,-4] → [[-1,-1,2],[-1,0,1]]"], solution: "function threeSum(nums){nums.sort((a,b)=>a-b);const out=[];for(let i=0;i<nums.length-2;i++){if(i&&nums[i]===nums[i-1])continue;let l=i+1,r=nums.length-1;while(l<r){const s=nums[i]+nums[l]+nums[r];if(s===0){out.push([nums[i],nums[l],nums[r]]);while(l<r&&nums[l]===nums[l+1])l++;while(l<r&&nums[r]===nums[r-1])r--;l++;r--;}else if(s<0)l++;else r--;}}return out;}", timeComplexity: "O(n²)", spaceComplexity: "O(1) excl. output" },
    { id: "tp-4", topicId: "two-pointers", title: "Trapping Rain Water", difficulty: "Hard", tags: ["two-pointers", "stack", "dp"], problem: "Compute trapped water between bars.", constraints: ["1 <= n <= 2*10⁴"], approach: "Two pointers tracking left/right max; water at i is min(leftMax,rightMax) - height[i].", dryRun: ["[0,1,0,2,1,0,1,3,2,1,2,1] → 6"], solution: "function trap(h){let l=0,r=h.length-1,lMax=0,rMax=0,w=0;while(l<r){if(h[l]<h[r]){lMax=Math.max(lMax,h[l]);w+=lMax-h[l];l++;}else{rMax=Math.max(rMax,h[r]);w+=rMax-h[r];r--;}}return w;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "tp-5", topicId: "two-pointers", title: "Valid Palindrome", difficulty: "Easy", tags: ["two-pointers", "string"], problem: "True if s is a palindrome considering only alphanumeric.", constraints: ["1 <= s.length <= 2*10⁵"], approach: "Two pointers, skip non-alphanumeric, compare lowercased.", dryRun: ["'A man, a plan, a canal: Panama' → true"], solution: "function isPalindrome(s){let l=0,r=s.length-1;while(l<r){while(l<r&&!/[a-zA-Z0-9]/.test(s[l]))l++;while(l<r&&!/[a-zA-Z0-9]/.test(s[r]))r--;if(s[l].toLowerCase()!==s[r].toLowerCase())return false;l++;r--;}return true;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "sw-3", topicId: "two-pointers", title: "Longest Repeating Character Replacement", difficulty: "Medium", tags: ["sliding-window"], problem: "(also in hashing) Same problem.", constraints: ["see above"], approach: "see above", dryRun: ["see above"], solution: "see above", timeComplexity: "O(n)", spaceComplexity: "O(1)" },

    // Linked lists extras
    { id: "ll-5", topicId: "linked-lists", title: "Remove Nth From End", difficulty: "Medium", tags: ["linked-list", "two-pointers"], problem: "Remove the n-th node from the end.", constraints: ["1 <= n <= len"], approach: "Slow/fast with n gap; dummy head for the removal case.", dryRun: ["[1,2,3,4,5], n=2 → [1,2,3,5]"], solution: "function removeNth(head,n){const d={next:head};let s=d,f=d;for(let i=0;i<n;i++)f=f.next;while(f.next){s=s.next;f=f.next;}s.next=s.next.next;return d.next;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "ll-6", topicId: "linked-lists", title: "Add Two Numbers", difficulty: "Medium", tags: ["linked-list", "math"], problem: "Two non-empty linked lists representing digits. Return sum as a list.", constraints: ["0 <= digit <= 9"], approach: "Walk both, carry. Dummy head.", dryRun: ["[2,4,3] + [5,6,4] → [8,0,7] (342+465=807)"], solution: "function add(l,r){const d={next:null},t=d;let c=0;while(l||r||c){const s=(l?.val??0)+(r?.val??0)+c;t.next={val:s%10,next:null};c=s>=10?1:0;t=t.next;l=l?.next;r=r?.next;}return d.next;}", timeComplexity: "O(max(m,n))", spaceComplexity: "O(max(m,n))" },
    { id: "ll-7", topicId: "linked-lists", title: "LRU Cache", difficulty: "Medium", tags: ["linked-list", "design", "hashmap"], problem: "Design LRU cache: O(1) get and put.", constraints: ["1 <= capacity <= 3000"], approach: "Doubly-linked list + hashmap of key→node. Most recent at head.", dryRun: ["LRUCache(2); put(1,1); put(2,2); get(1)→1; put(3,3) evicts 2"], solution: "class LRUCache { constructor(c){this.c=c;this.m=new Map();} get(k){if(!this.m.has(k))return -1;const v=this.m.get(k);this.m.delete(k);this.m.set(k,v);return v;} put(k,v){if(this.m.has(k))this.m.delete(k);if(this.m.size===this.c){const fk=this.m.keys().next().value;this.m.delete(fk);}this.m.set(k,v);} }", timeComplexity: "O(1)", spaceComplexity: "O(c)" },

    // Stack/queue extras
    { id: "sq-4", topicId: "stacks-queues", title: "Evaluate Reverse Polish Notation", difficulty: "Medium", tags: ["stack"], problem: "Evaluate RPN expression.", constraints: ["1 <= tokens <= 10⁴"], approach: "Stack: push numbers, pop two on operator, push result.", dryRun: ["['2','1','+','3','*'] → 9"], solution: "function evalRPN(t){const st=[];for(const x of t){if('+-*/'.includes(x)){const b=st.pop(),a=st.pop();st.push(x==='+'?a+b:x==='-'?a-b:x==='*'?a*b:Math.trunc(a/b));}else st.push(+x);}return st[0];}", timeComplexity: "O(n)", spaceComplexity: "O(n)" },
    { id: "sq-5", topicId: "stacks-queues", title: "Sliding Window Maximum", difficulty: "Hard", tags: ["deque", "sliding-window"], problem: "Max in each window of size k.", constraints: ["1 <= k <= n <= 10⁵"], approach: "Monotonic deque of indices (decreasing values).", dryRun: ["[1,3,-1,-3,5,3,6,7], k=3 → [3,3,5,5,6,7]"], solution: "function maxSlidingWindow(a,k){const d=[],out=[];for(let i=0;i<a.length;i++){while(d.length&&a[d.at(-1)]<a[i])d.pop();d.push(i);if(d[0]<=i-k)d.shift();if(i>=k-1)out.push(a[d[0]]);}return out;}", timeComplexity: "O(n)", spaceComplexity: "O(k)" },
    { id: "sq-6", topicId: "stacks-queues", title: "Largest Rectangle in Histogram", difficulty: "Hard", tags: ["stack", "monotonic"], problem: "Largest rectangle area in a histogram.", constraints: ["1 <= n <= 10⁵"], approach: "Monotonic increasing stack; on a drop, pop and compute area.", dryRun: ["[2,1,5,6,2,3] → 10"], solution: "function largestRectangle(h){const st=[];let best=0;for(let i=0;i<=h.length;i++){const cur=i===h.length?0:h[i];while(st.length&&h[st.at(-1)]>cur){const t=st.pop(),w=st.length?i-st.at(-1)-1:i;best=Math.max(best,h[t]*w);}st.push(i);}return best;}", timeComplexity: "O(n)", spaceComplexity: "O(n)" },

    // Tree extras
    { id: "t-6", topicId: "trees", title: "Construct Binary Tree from Preorder and Inorder", difficulty: "Medium", tags: ["tree", "recursion"], problem: "Build tree from preorder and inorder traversals.", constraints: ["1 <= n <= 3000"], approach: "First preorder element is root; find in inorder to split left/right.", dryRun: ["pre=[3,9,20,15,7], in=[9,3,15,20,7] → standard tree"], solution: "function buildTree(pre,ino){if(!pre.length)return null;const r={val:pre[0]};const i=ino.indexOf(pre[0]);r.left=buildTree(pre.slice(1,i+1),ino.slice(0,i));r.right=buildTree(pre.slice(i+1),ino.slice(i+1));return r;}", timeComplexity: "O(n²) naively, O(n) with map", spaceComplexity: "O(n)" },
    { id: "t-7", topicId: "trees", title: "Serialize and Deserialize Binary Tree", difficulty: "Hard", tags: ["tree", "bfs", "design"], problem: "Encode tree to string and back.", constraints: ["0 <= n <= 10⁴"], approach: "BFS with nulls; deserialize with queue.", dryRun: ["[1,2,3,null,null,4,5] ↔ '1,2,3,null,null,4,5'"], solution: "function serialize(r){if(!r)return'#';return r.val+','+serialize(r.left)+','+serialize(r.right);}function deserialize(s){const t=s.split(',');const f=()=>{const v=t.shift();return v==='#'?null:{val:+v,left:f(),right:f()};};return f();}", timeComplexity: "O(n)", spaceComplexity: "O(n)" },
    { id: "t-8", topicId: "trees", title: "Path Sum", difficulty: "Easy", tags: ["tree", "dfs"], problem: "True if root-to-leaf path sums to target.", constraints: ["0 <= n <= 5000"], approach: "DFS subtract target; leaf check at null.", dryRun: ["[5,4,8,11,null,13,4,7,2], target=22 → true"], solution: "function hasPathSum(r,t){if(!r)return false;if(!r.left&&!r.right)return t===r.val;return hasPathSum(r.left,t-r.val)||hasPathSum(r.right,t-r.val);}", timeComplexity: "O(n)", spaceComplexity: "O(h)" },
    { id: "t-9", topicId: "trees", title: "Binary Tree Maximum Path Sum", difficulty: "Hard", tags: ["tree", "dfs", "dp"], problem: "Max path sum (any node to any node).", constraints: ["1 <= n <= 3*10⁴"], approach: "DFS: gain-through-root = node + max(leftGain, rightGain, 0). Update global with node + left + right.", dryRun: ["[-10,9,20,null,null,15,7] → 42"], solution: "function maxPathSum(r){let best=-Infinity;const dfs=n=>{if(!n)return 0;const l=Math.max(0,dfs(n.left)),rt=Math.max(0,dfs(n.right));best=Math.max(best,n.val+l+rt);return n.val+Math.max(l,rt);};dfs(r);return best;}", timeComplexity: "O(n)", spaceComplexity: "O(h)" },

    // Heaps extras
    { id: "hp-3", topicId: "heaps", title: "Task Scheduler", difficulty: "Medium", tags: ["heap", "greedy"], problem: "Minimum intervals to finish tasks with same-type cooldown.", constraints: ["1 <= n <= 10⁴"], approach: "Max-heap of counts; idle-fill.", dryRun: ["['A','A','A','B','B','B'], n=2 → 8"], solution: "// see NeetCode", timeComplexity: "O(n)", spaceComplexity: "O(26)" },
    { id: "hp-4", topicId: "heaps", title: "Find Median from Data Stream", difficulty: "Hard", tags: ["heap", "design"], problem: "AddNum + findMedian in O(log n).", constraints: ["stream up to 10⁵"], approach: "Two heaps: max-heap for lower half, min-heap for upper half. Rebalance sizes.", dryRun: ["add 1,2 → median 1.5; add 3 → 2"], solution: "class MedianFinder { constructor(){this.lo=new MaxHeap();this.hi=new MinHeap();} addNum(n){this.lo.push(n);this.hi.push(this.lo.pop());if(this.lo.size()<this.hi.size())this.lo.push(this.hi.pop());} findMedian(){return this.lo.size()>this.hi.size()?this.lo.peek():(this.lo.peek()+this.hi.peek())/2;} }", timeComplexity: "O(log n) per add", spaceComplexity: "O(n)" },

    // Graph extras
    { id: "g-4", topicId: "graphs", title: "Clone Graph", difficulty: "Medium", tags: ["graph", "dfs", "hashmap"], problem: "Deep-copy an undirected graph.", constraints: ["0 <= n <= 100"], approach: "DFS with map old→new; recurse neighbors.", dryRun: ["adj=[[2,4],[1,3],[2,4],[1,3]] → cloned"], solution: "function clone(n){if(!n)return null;const m=new Map();const dfs=o=>{if(m.has(o))return m.get(o);const c=new Node(o.val);m.set(o,c);for(const x of o.neighbors)c.neighbors.push(dfs(x));return c;};return dfs(n);}", timeComplexity: "O(V+E)", spaceComplexity: "O(V)" },
    { id: "g-5", topicId: "graphs", title: "Pacific Atlantic Water Flow", difficulty: "Medium", tags: ["graph", "bfs", "dfs"], problem: "Cells from which water can reach both oceans.", constraints: ["1 <= m,n <= 150"], approach: "BFS from ocean borders inward; intersect reachable sets.", dryRun: ["standard example → output list"], solution: "function pacificAtlantic(h){const m=h.length,n=h[0].length;const reach=()=>{const v=Array.from({length:m},()=>new Array(n).fill(false)),q=[];return (cells)=>{for(const[i,j]of cells){q.push([i,j]);v[i][j]=true;}const dirs=[[1,0],[-1,0],[0,1],[0,-1]];while(q.length){const[i,j]=q.shift();for(const[di,dj]of dirs){const ni=i+di,nj=j+dj;if(ni>=0&&nj>=0&&ni<m&&nj<n&&!v[ni][nj]&&h[ni][nj]>=h[i][j]){v[ni][nj]=true;q.push([ni,nj]);}}}return v;};};const p=reach()([[0,j]for(j=0..n-1)]+[[i,0]for(i=0..m-1)]);const a=reach()([[m-1,j]for(j=0..n-1)]+[[i,n-1]for(i=0..m-1)]);const out=[];for(let i=0;i<m;i++)for(let j=0;j<n;j++)if(p[i][j]&&a[i][j])out.push([i,j]);return out;}", timeComplexity: "O(mn)", spaceComplexity: "O(mn)" },
    { id: "g-6", topicId: "graphs", title: "Redundant Connection", difficulty: "Medium", tags: ["graph", "union-find"], problem: "Edge whose removal makes the graph a tree.", constraints: ["n == edges.length"], approach: "Union-Find: first edge whose endpoints already connected.", dryRun: ["[[1,2],[1,3],[2,3]] → [2,3]"], solution: "function findRedundant(edges){const p=Array.from({length:edges.length+1},(_,i)=>i);const f=x=>p[x]===x?x:(p[x]=f(p[x]),p[x]);for(const[a,b]of edges)if(f(a)===f(b))return[a,b];else p[f(a)]=f(b);}", timeComplexity: "O(n·α(n))", spaceComplexity: "O(n)" },

    // Recursion extras
    { id: "r-4", topicId: "recursion", title: "Combination Sum", difficulty: "Medium", tags: ["backtracking"], problem: "All unique combinations that sum to target (reuse elements).", constraints: ["1 <= candidates <= 30"], approach: "Backtrack with start index; reuse allowed.", dryRun: ["[2,3,6,7], target=7 → [[2,2,3],[7]]"], solution: "function cs(c,t){const out=[],cur=[];c.sort((a,b)=>a-b);const bt=(i,s)=>{if(s===t){out.push([...cur]);return;}for(let j=i;j<c.length;j++){if(s+c[j]>t)break;cur.push(c[j]);bt(j,s+c[j]);cur.pop();}};bt(0,0);return out;}", timeComplexity: "O(n^(t/min))", spaceComplexity: "O(t/min)" },
    { id: "r-5", topicId: "recursion", title: "Letter Combinations of a Phone Number", difficulty: "Medium", tags: ["backtracking", "string"], problem: "Return all letter combos for a digit string.", constraints: ["0 <= digits.length <= 4"], approach: "Backtrack through digit letters.", dryRun: ["'23' → ['ad','ae','af','bd','be','bf','cd','ce','cf']"], solution: "function lc(d){if(!d.length)return[];const m={'2':'abc','3':'def','4':'ghi','5':'jkl','6':'mno','7':'pqrs','8':'tuv','9':'wxyz'};const out=[];const bt=(i,cur)=>{if(i===d.length){out.push(cur);return;}for(const c of m[d[i]])bt(i+1,cur+c);};bt(0,'');return out;}", timeComplexity: "O(4ⁿ)", spaceComplexity: "O(n)" },

    // DP extras
    { id: "dp-6", topicId: "dp", title: "House Robber", difficulty: "Medium", tags: ["dp", "1d"], problem: "Max money robbing non-adjacent houses.", constraints: ["1 <= n <= 100"], approach: "dp[i] = max(dp[i-1], dp[i-2]+nums[i]).", dryRun: ["[1,2,3,1] → 4 (1+3)"], solution: "function rob(a){let p2=0,p1=0;for(const n of a){[p2,p1]=[p1,Math.max(p1,p2+n)];}return p1;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "dp-7", topicId: "dp", title: "House Robber II (Circle)", difficulty: "Medium", tags: ["dp", "1d"], problem: "Same as house robber but houses in a circle.", constraints: ["1 <= n <= 100"], approach: "Run house robber on [0..n-2] and [1..n-1], take max.", dryRun: ["[2,3,2] → 3"], solution: "function rob2(a){if(a.length<2)return a[0]||0;return Math.max(rob(a.slice(0,-1)),rob(a.slice(1)));function rob(b){let p2=0,p1=0;for(const n of b){[p2,p1]=[p1,Math.max(p1,p2+n)];}return p1;}}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "dp-8", topicId: "dp", title: "Longest Increasing Subsequence", difficulty: "Medium", tags: ["dp", "binary-search"], problem: "Length of LIS.", constraints: ["0 <= n <= 2500"], approach: "Patience sort: maintain tails; for each x, lower_bound in tails.", dryRun: ["[10,9,2,5,3,7,101,18] → 4"], solution: "function lis(a){const t=[];for(const x of a){let lo=0,hi=t.length;while(lo<hi){const m=(lo+hi)>>1;if(t[m]<x)lo=m+1;else hi=m;}t[lo]=x;}return t.length;}", timeComplexity: "O(n log n)", spaceComplexity: "O(n)" },
    { id: "dp-9", topicId: "dp", title: "Edit Distance", difficulty: "Hard", tags: ["dp", "2d", "string"], problem: "Min operations (insert, delete, replace) to convert word1 to word2.", constraints: ["0 <= m,n <= 500"], approach: "2D DP: dp[i][j] = dp[i-1][j-1] if match else 1 + min of three neighbors.", dryRun: ["'horse'→'ros' → 3"], solution: "function minDistance(a,b){const m=a.length,n=b.length;const dp=Array.from({length:m+1},(_,i)=>Array.from({length:n+1},(_,j)=>i?j?0:i:j));for(let i=1;i<=m;i++)for(let j=1;j<=n;j++)dp[i][j]=a[i-1]===b[j-1]?dp[i-1][j-1]:1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);return dp[m][n];}", timeComplexity: "O(mn)", spaceComplexity: "O(mn)" },
    { id: "dp-10", topicId: "dp", title: "Decode Ways", difficulty: "Medium", tags: ["dp", "string"], problem: "Count decodings of a digit string ('1'=A, ..., '26'=Z).", constraints: ["1 <= s <= 100"], approach: "dp[i] = dp[i-1] (if s[i-1]≠'0') + dp[i-2] (if last two digits form 10..26).", dryRun: ["'226' → 3 (BBF,BZ,VF)"], solution: "function numDecodings(s){if(!s||s[0]==='0')return 0;const dp=new Array(s.length+1).fill(0);dp[0]=1;dp[1]=1;for(let i=2;i<=s.length;i++){if(s[i-1]!=='0')dp[i]+=dp[i-1];const t=+s.slice(i-2,i);if(t>=10&&t<=26)dp[i]+=dp[i-2];}return dp[s.length];}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },

    // Greedy extras
    { id: "gr-3", topicId: "greedy", title: "Gas Station", difficulty: "Medium", tags: ["greedy"], problem: "Find starting gas station to complete the circuit.", constraints: ["n == gas.length == cost.length"], approach: "If total gas < total cost, no answer. Else start at the index where running sum dips lowest after.", dryRun: ["gas=[1,2,3,4,5], cost=[3,4,5,1,2] → 3"], solution: "function canComplete(g,c){let total=0,tank=0,start=0;for(let i=0;i<g.length;i++){total+=g[i]-c[i];tank+=g[i]-c[i];if(tank<0){start=i+1;tank=0;}}return total<0?-1:start;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "gr-4", topicId: "greedy", title: "Hand of Straights", difficulty: "Medium", tags: ["greedy", "hashmap"], problem: "Reorder into groups of consecutive W.", constraints: ["1 <= hand.length <= 10⁴"], approach: "Count, then greedily build groups from smallest.", dryRun: ["[1,2,3,6,2,3,4,7,8], W=3 → true"], solution: "function isNStraightHand(h,W){if(h.length%W)return false;h.sort((a,b)=>a-b);const c=new Map();for(const x of h)c.set(x,(c.get(x)??0)+1);for(const x of h){if(!c.get(x))continue;for(let i=0;i<W;i++){const k=x+i;if((c.get(k)??0)<=0)return false;c.set(k,c.get(k)-1);}}return true;}", timeComplexity: "O(n log n)", spaceComplexity: "O(n)" },
    { id: "gr-5", topicId: "greedy", title: "Partition Labels", difficulty: "Medium", tags: ["greedy", "string"], problem: "Partition string into max pieces where each letter appears in at most one piece.", constraints: ["1 <= s <= 100"], approach: "Record last index of each char; extend current piece to last seen.", dryRun: ["'ababcbacadefegdehijhklij' → [9,7,8]"], solution: "function partitionLabels(s){const last={};for(let i=0;i<s.length;i++)last[s[i]]=i;const out=[];let start=0,end=0;for(let i=0;i<s.length;i++){end=Math.max(end,last[s[i]]);if(i===end){out.push(end-start+1);start=i+1;}}return out;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },

    // Binary search extras
    { id: "bs-3", topicId: "binary-search", title: "Find Minimum in Rotated Sorted Array", difficulty: "Medium", tags: ["binary-search"], problem: "Find min in array with no duplicates.", constraints: ["1 <= n <= 5000"], approach: "BS, comparing mid to right to decide which half is sorted.", dryRun: ["[3,4,5,1,2] → 1"], solution: "function findMin(a){let lo=0,hi=a.length-1;while(lo<hi){const m=(lo+hi)>>1;if(a[m]>a[hi])lo=m+1;else hi=m;}return a[lo];}", timeComplexity: "O(log n)", spaceComplexity: "O(1)" },
    { id: "bs-4", topicId: "binary-search", title: "Search a 2D Matrix", difficulty: "Medium", tags: ["binary-search", "matrix"], problem: "Search in row-sorted, column-sorted matrix.", constraints: ["1 <= m,n <= 100"], approach: "Treat as 1D sorted array of length m*n; BS on virtual index.", dryRun: ["standard 2D matrix, target=5 → true"], solution: "function searchMatrix(m,t){const r=m.length,c=m[0].length;let lo=0,hi=r*c-1;while(lo<=hi){const mid=(lo+hi)>>1;const v=m[Math.floor(mid/c)][mid%c];if(v===t)return true;if(v<t)lo=mid+1;else hi=mid-1;}return false;}", timeComplexity: "O(log(mn))", spaceComplexity: "O(1)" },
    { id: "bs-5", topicId: "binary-search", title: "Time Based Key-Value Store", difficulty: "Medium", tags: ["binary-search", "design", "hashmap"], problem: "Set(key,value,ts); Get(key,ts) returns value at largest ts <= given.", constraints: ["0 <= ts <= 10⁷"], approach: "Map<key,[[ts,val],...]>; upper_bound on timestamps.", dryRun: ["set(foo,bar,1); get(foo,1)→bar; get(foo,3)→bar"], solution: "class TimeMap { constructor(){this.m=new Map();} set(k,v,t){(this.m.get(k)??this.m.set(k,[]).get(k)).push([t,v]);} get(k,t){const a=this.m.get(k)??[];let lo=0,hi=a.length-1,ans='';while(lo<=hi){const m=(lo+hi)>>1;if(a[m][0]<=t){ans=a[m][1];lo=m+1;}else hi=m-1;}return ans;} }", timeComplexity: "O(log n) get", spaceComplexity: "O(n)" },

    // Sorting extras
    { id: "so-2", topicId: "sorting", title: "Sort Colors (Dutch National Flag)", difficulty: "Medium", tags: ["sorting", "two-pointers"], problem: "Sort array of 0/1/2 in-place in one pass.", constraints: ["0 <= n <= 300"], approach: "Three-way partition with low, mid, high pointers.", dryRun: ["[2,0,2,1,1,0] → [0,0,1,1,2,2]"], solution: "function sortColors(a){let l=0,m=0,r=a.length-1;while(m<=r){if(a[m]===0){[a[l],a[m]]=[a[m],a[l]];l++;m++;}else if(a[m]===1){m++;}else{[a[m],a[r]]=[a[r],a[m]];r--;}}}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "so-3", topicId: "sorting", title: "Top K Frequent Words", difficulty: "Medium", tags: ["sorting", "hashmap", "heap"], problem: "Return k most frequent words, lex-sorted on ties.", constraints: ["1 <= words.length <= 500"], approach: "Count + sort by [-freq, word].", dryRun: ["['i','love','leetcode','i','love','coding'], k=2 → ['i','love']"], solution: "function topKFrequent(words,k){const m=new Map();for(const w of words)m.set(w,(m.get(w)??0)+1);return [...m.entries()].sort((a,b)=>b[1]-a[1]||a[0].localeCompare(b[0])).slice(0,k).map(x=>x[0]);}", timeComplexity: "O(n log n)", spaceComplexity: "O(n)" },

    // Bit manipulation extras
    { id: "bi-4", topicId: "bits", title: "Reverse Bits", difficulty: "Easy", tags: ["bits"], problem: "Reverse bits of a 32-bit unsigned integer.", constraints: ["0 <= n <= 2³²-1"], approach: "Iterate 32 times, shifting result left and n right.", dryRun: ["0b00000010100101000001111010011100 → 964176192"], solution: "function reverseBits(n){let r=0;for(let i=0;i<32;i++){r=(r<<1)|(n&1);n>>>=1;}return r>>>0;}", timeComplexity: "O(1)", spaceComplexity: "O(1)" },
    { id: "bi-5", topicId: "bits", title: "Missing Number", difficulty: "Easy", tags: ["bits", "math"], problem: "Find missing in [0,n] given n distinct numbers.", constraints: ["0 <= n <= 10⁴"], approach: "XOR indices with values cancels; missing remains.", dryRun: ["[3,0,1] → 2"], solution: "function missingNumber(a){let x=a.length;for(let i=0;i<a.length;i++)x^=i^a[i];return x;}", timeComplexity: "O(n)", spaceComplexity: "O(1)" },
    { id: "bi-6", topicId: "bits", title: "Sum of Two Integers (No + or -)", difficulty: "Medium", tags: ["bits"], problem: "Add a and b without + or -.", constraints: ["-1000 <= a,b <= 1000"], approach: "XOR for sum without carry, AND<<1 for carry, repeat until carry zero.", dryRun: ["1+2 → 3"], solution: "function getSum(a,b){while(b!==0){const c=(a&b)<<1;a=a^b;b=c;}return a;}", timeComplexity: "O(1)", spaceComplexity: "O(1)" },
  ];
  return fillers.map((f) => stub(f));
}

export const QUESTIONS: Question[] = [
  TWO_SUM_SORTED,
  CONTAINER_WITH_MOST_WATER,
  LONGEST_SUBARRAY,
  MIN_WINDOW_SUBSTRING,
  ...STUB_QUESTIONS,
];

export const QUESTION_BY_ID: Record<string, Question> = Object.fromEntries(
  QUESTIONS.map((q) => [q.id, q])
);
