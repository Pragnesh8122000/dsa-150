  stub({ id: "arr-5", topicId: "arrays", title: "Valid Anagram", difficulty: "Easy", tags: ["hashmap", "string"], problem: "Determine if t is an anagram of s.", constraints: ["1 <= s.length, t.length <= 5*10⁴"], approach: "Count chars in s, decrement for t, check all zero.", dryRun: ["s='anagram', t='nagaram' → true"], solution: "function isAnagram(s,t) {\n  if (s.length!==t.length) return false;\n  const c=new Array(26).fill(0);\n  for (let i=0;i<s.length;i++) { c[s.charCodeAt(i)-97]++; c[t.charCodeAt(i)-97]--; }\n  return c.every(x=>x===0);\n}", timeComplexity: "O(n)", spaceComplexity: "O(1)" }),

